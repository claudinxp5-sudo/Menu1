local isEspEnabled = false
local isEspLineEnabled = false
local isEspBoxEnabled = false
local espColor = Color3.fromRGB(255, 0, 0) -- Cor inicial vermelha
local espHighlights = {}
local espLines = {}
local espBoxes = {}

local function createEspHighlight(target)
    local highlight = Instance.new("Highlight")
    highlight.Adornee = target
    highlight.FillColor = espColor
    highlight.OutlineColor = espColor
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Parent = target
    return highlight
end

local function createEspLine(target)
    local line = Instance.new("Part")
    line.Name = "EspLine"
    line.Anchored = true
    line.CanCollide = false
    line.Transparency = 0.5
    line.BrickColor = BrickColor.new(espColor)
    line.FormFactor = Enum.FormFactor.Custom
    line.Size = Vector3.new(0.1, 0.1, 0.1)
    line.Parent = workspace
    return line
end

local function createEspBox(target)
    local box = Instance.new("BoxHandleAdornment")
    box.Adornee = target
    box.Color = espColor
    box.AlwaysOnTop = true
    box.ZIndex = 10
    box.Parent = target
    return box
end

local function updateEsp()
    for _, highlight in pairs(espHighlights) do highlight:Destroy() end
    for _, line in pairs(espLines) do line:Destroy() end
    for _, box in pairs(espBoxes) do box:Destroy() end
    espHighlights = {}
    espLines = {}
    espBoxes = {}

    if not isEspEnabled then return end

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
            local target = player.Character.HumanoidRootPart
            if target then
                local highlight = createEspHighlight(target)
                table.insert(espHighlights, highlight)

                if isEspLineEnabled then
                    local line = createEspLine(target)
                    table.insert(espLines, line)
                end

                if isEspBoxEnabled then
                    local box = createEspBox(target)
                    table.insert(espBoxes, box)
                end
            end
        end
    end
    -- Adicionar lógica para NPCs aqui, se necessário
end

local function updateEspLinesAndBoxes()
    if not isEspEnabled then return end

    for i, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
            local target = player.Character.HumanoidRootPart
            if target then
                if isEspLineEnabled and espLines[i] then
                    local line = espLines[i]
                    local origin = LocalPlayer.Character.HumanoidRootPart.Position
                    local destination = target.Position
                    local distance = (origin - destination).Magnitude
                    line.Size = Vector3.new(0.1, 0.1, distance)
                    line.CFrame = CFrame.new(origin, destination) * CFrame.new(0, 0, -distance / 2)
                end

                if isEspBoxEnabled and espBoxes[i] then
                    local box = espBoxes[i]
                    box.Adornee = target
                end
            end
        end
    end
end

EspToggle.MouseButton1Click:Connect(function()
