-- MOVIMENTO TAB CONTENT
local function toggleFly(active)
    _G.BrasilMenuConfig.Fly = active
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    
    if active then
        hum.PlatformStand = true
        local bg = Instance.new("BodyGyro")
        bg.Name = "BrasilFlyGyro"
        bg.P = 9e4; bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9); bg.CFrame = hrp.CFrame; bg.Parent = hrp
        local bv = Instance.new("BodyVelocity")
        bv.Name = "BrasilFlyVel"
        bv.Velocity = Vector3.new(0,0,0); bv.MaxForce = Vector3.new(9e9, 9e9, 9e9); bv.Parent = hrp
    else
        hum.PlatformStand = false
        if hrp:FindFirstChild("BrasilFlyGyro") then hrp.BrasilFlyGyro:Destroy() end
        if hrp:FindFirstChild("BrasilFlyVel") then hrp.BrasilFlyVel:Destroy() end
    end
end

createToggle(MovementTab, "Fly (Andar no Ar)", toggleFly)
createSlider(MovementTab, "Velocidade Fly", 0, 500, 50, function(v) _G.BrasilMenuConfig.FlySpeed = v end)
