local function GetClosestPlayerInFOV(camera, fovRadius, maxDistance, onlyVisible)
local closestPlayer = nil
local closestDistance = math.huge
local cameraPos = camera.CFrame.Position
local viewportSize = camera.ViewportSize

for _, player in ipairs(Players:GetPlayers()) do
if player ~= LocalPlayer and player.Character then
local humanoidRootPart = player.Character:FindFirstChild("HumanoidRootPart")
if humanoidRootPart then
local targetPos = humanoidRootPart.Position
local distance = (targetPos - cameraPos).Magnitude

if distance <= maxDistance then
local screenPoint, onScreen = camera:WorldToViewportPoint(targetPos)
if onScreen then
local centerX, centerY = viewportSize.X / 2, viewportSize.Y / 2
local distToCenter = (Vector2.new(screenPoint.X, screenPoint.Y) - Vector2.new(centerX, centerY)).Magnitude
if distToCenter <= fovRadius then
if not onlyVisible or true then -- Simplificado para não travar com raycast pesado
if distance < closestDistance then
closestDistance = distance
closestPlayer = player
end
end
end
end
end
end
end
end
return closestPlayer
end

local function UpdateAimbot()
if not State.AimbotAtivado then
if AimbotConnection then
AimbotConnection:Disconnect()
AimbotConnection = nil
end
return
end

if not AimbotConnection then
AimbotConnection = RunService.RenderStepped:Connect(function()
if not State.AimbotAtivado then return end

local camera = Camera
local targetPlayer = GetClosestPlayerInFOV(
camera,
State.AimbotFOV,
State.AimbotDistanciaMax,
State.AimbotOnlyVisible
)

if targetPlayer then
local rootPart = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
if rootPart then
local targetPos = rootPart.Position
local cameraCFrame = camera.CFrame
local direction = (targetPos - cameraCFrame.Position).Unit

-- Suavização simples
local currentLook = cameraCFrame.LookVector
local smoothFactor = 1 / math.max(1, State.AimbotSuavidade)
local smoothedDirection = currentLook:Lerp(direction, smoothFactor)

camera.CFrame = CFrame.new(cameraCFrame.Position, cameraCFrame.Position + smoothedDirection)
end
end
end)
end
end
