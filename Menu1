local function OpenMenu()
	isOpen = true
	MainFrame.Visible = true
	MainFrame.Size = UDim2.fromOffset(fullSize.X.Offset * 0.7, fullSize.Y.Offset * 0.7)
	MainFrame.Position = UDim2.new(0.5, -fullSize.X.Offset * 0.3* 0.35, 0.5, -fullSize.Y.Offset * 0.35)
	MainFrame.BackgroundTransparency = 1

	local targetPos = UDim2.new(0.5, -fullSize.X.Offset / 2, 0.5, -fullSize.Y.Offset / 2)

	TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
Size = fullSize,
Position = targetPos,
BackgroundTransparency = 0,
	}):Play()

	Notify("Brasil Menu", "Painel aberto!", 2)
end

local function CloseMenu()
	isOpen = false
	local tween = TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
Size = UDim2.fromOffset(fullSize.X.Offset * 0.7, fullSize.Y.Offset * 0.7),
Position = UDim2.new(0.5, -fullSize.X.Offset * 0.35, 0.5, -fullSize.Y.Offset * 0.35),
BackgroundTransparency = 1,
	})
	tween:Play()
	tween.Completed:Wait()
	MainFrame.Visible = false
	MainFrame.BackgroundTransparency = 0
end

local function ToggleMinimize()
