local function UpdateESPBox(targetPlayer, box, nameLabel, distLabel)
	local char = targetPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local myHrp = GetCharacter() and GetCharacter():FindFirstChild("HumanoidRootPart")
	if not hrp or not myHrp then
box.Visible = false
return
	end

	local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
	if onScreen then
box.Visible = true
box.Position = UDim2.fromOffset(pos.X - 40, pos.Y - 60)

if nameLabel then
nameLabel.Visible = State.MostrarNomes
nameLabel.Text = targetPlayer.Name
end
if distLabel then
distLabel.Visible = State.MostrarDistancia
local dist = math.floor((myHrp.Position - hrp.Position).Magnitude)
distLabel.Text = dist.. "m"
end
	else
box.Visible = false
	end
end

