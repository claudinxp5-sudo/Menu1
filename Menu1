local tabs = {}
local function createTab(name)
    local tab = Instance.new("ScrollingFrame")
    tab.Size = UDim2.new(1, 0, 1, 0)
    tab.BackgroundTransparency = 1
    tab.Visible = false
    tab.ScrollBarThickness = 0
    tab.CanvasSize = UDim2.new(0, 0, 1.5, 0)
