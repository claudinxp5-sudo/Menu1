local minSpeed = 0
local maxSpeed = 100
local currentSpeed = 16

local function updateSpeed(newSpeed)
    currentSpeed = math.clamp(newSpeed, minSpeed, maxSpeed)
    SpeedLabel.Text = "Velocidade: " .. math.floor(currentSpeed)
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = currentSpeed
    end
    local fillRatio = (currentSpeed - minSpeed) / (maxSpeed - minSpeed)
    SpeedSliderFill.Size = UDim2.new(fillRatio, 0, 1, 0)
    SpeedSliderHandle.Position = UDim2.new(fillRatio, -SpeedSliderHandle.Size.X.Offset / 2, 0, 0)
end

SpeedSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local function onInputChanged(input2)
            if input2.UserInputType == Enum.UserInputType.MouseButton1 or input2.UserInputType == Enum.UserInputType.Touch then
                local mousePos = UserInputService:GetMouseLocation()
                local sliderPos = SpeedSlider.AbsolutePosition
                local sliderSize = SpeedSlider.AbsoluteSize
                local relativeX = math.clamp((mousePos.X - sliderPos.X) / sliderSize.X, 0, 1)
                local newSpeed = minSpeed + (maxSpeed - minSpeed) * relativeX
                updateSpeed(newSpeed)
            end
        end
        local inputChangedConn = UserInputService.InputChanged:Connect(onInputChanged)
        local inputEndedConn = UserInputService.InputEnded:Connect(function(input2)
            if input2.UserInputType == Enum.UserInputType.MouseButton1 or input2.UserInputType == Enum.UserInputType.Touch then
                inputChangedConn:Disconnect()
                inputEndedConn:Disconnect()
            end
        end)
    end
end)

-- Inicializa a velocidade
updateSpeed(currentSpeed)

-- Atualiza a velocidade caso o personagem seja recarregado
LocalPlayer.CharacterAdded:Connect(function(character)
    character:WaitForChild("Humanoid"):GetPropertyChangedSignal("WalkSpeed"):Wait()
    updateSpeed(currentSpeed)
end)

