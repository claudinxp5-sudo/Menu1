local isFlying = false
local flySpeed = 1
local camera = workspace.CurrentCamera

local function toggleFly()
    isFlying = not isFlying
    FlyToggle.Text = "Fly: " .. (isFlying and "ON" or "OFF")

    if isFlying then
        LocalPlayer.Character.Humanoid.PlatformStand = true
        LocalPlayer.Character.Humanoid.Sit = true -- Para evitar que o personagem caia
        LocalPlayer.Character.Humanoid.WalkSpeed = 0
        LocalPlayer.Character.Humanoid.JumpPower = 0
    else
        LocalPlayer.Character.Humanoid.PlatformStand = false
        LocalPlayer.Character.Humanoid.Sit = false
        LocalPlayer.Character.Humanoid.WalkSpeed = currentSpeed -- Retorna à velocidade definida
        LocalPlayer.Character.Humanoid.JumpPower = 50 -- Valor padrão
    end
end

FlyToggle.MouseButton1Click:Connect(toggleFly)

-- Controles de voo (mobile e teclado)
local function handleFlyMovement(dt)
    if not isFlying or not LocalPlayer.Character or not camera then return end

    local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end

    local moveVector = Vector3.new(0, 0, 0)

    -- Teclado (para testar no PC)
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector += camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector -= camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector -= camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector += camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveVector += Vector3.new(0, 1, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveVector -= Vector3.new(0, 1, 0) end

    -- Controles mobile (simples, pode ser expandido com joysticks virtuais)
    -- Para um controle mobile mais robusto, seria necessário um joystick virtual na tela.
    -- Por simplicidade, vamos usar toques na tela para cima/baixo/frente/trás
    -- if UserInputService.TouchEnabled then
    --     -- Exemplo básico: tocar na metade superior da tela move para frente, inferior para trás
    --     -- Isso é muito simplificado e precisaria de um joystick virtual para ser bom.
    --     -- Para o propósito de um painel de dev, pode ser aceitável.
    --     -- if touchDelta.Y < -5 then moveVector += camera.CFrame.LookVector end -- Mover para frente
    --     -- if touchDelta.Y > 5 then moveVector -= camera.CFrame.LookVector end  -- Mover para trás
    --     -- if touchDelta.X < -5 then moveVector -= camera.CFrame.RightVector end -- Mover para esquerda
    --     -- if touchDelta.X > 5 then moveVector += camera.CFrame.RightVector end  -- Mover para direita
    -- end

    if moveVector.Magnitude > 0 then
        rootPart.CFrame += moveVector.Unit * flySpeed * 20 * dt -- Multiplicado por 20 para ser mais rápido
    end
end

RunService.RenderStepped:Connect(handleFlyMovement)

