local function protect_gui(gui)
    if syn and syn.protect_gui then
        syn.protect_gui(gui)
    elseif gethui then
        gui.Parent = gethui()
    else
        gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end
end

