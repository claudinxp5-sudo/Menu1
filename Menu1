local function SalvarConfiguracoes()
	for key, value in pairs(State) do
if typeof(value) == "number" or typeof(value) == "boolean" then
LocalPlayer:SetAttribute("BM_".. key, value)
end
	end
	Notify("Configurações", "Configurações salvas com sucesso!", 3)
end

local function CarregarConfiguracoes()
	for key, _ in pairs(State) do
local saved = LocalPlayer:GetAttribute("BM_".. key)
if saved ~= nil then
State[key] = saved
end
	end
	-- Apply loaded settings
	SetWalkSpeed(State.WalkSpeed)
	SetJumpPower(State.JumpPower)
	if State.Fly then ToggleFly(true) end
	if State.NoClip then ToggleNoClip(true) end
	if State.InfiniteJump then ToggleInfiniteJump(true) end
	if State.FullBright then ToggleFullBright(true) end
	SetFOV(State.FOV)
	if State.Invisibilidade then ToggleInvisibilidade(true) end
	if State.ESP then ToggleESP(true) end
	SetGravity(State.Gravidade)
	if State.AimbotAtivado then UpdateAimbot() end

	Notify("Configurações", "Configurações carregadas!", 3)
end

