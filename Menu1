TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
Size = fullSize,
}):Play()
TabBar.Visible = true
PagesHolder.Visible = true
ResizeHandle.Visible = true
	end
end

